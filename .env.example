# MongoDB connection URL (only needed for ML training pipeline)
# Used by main.py to ingest and process data
# For local development, you can generate a MongoDB Atlas cluster at https://www.mongodb.com/cloud/atlas
MONGO_DB_URL=mongodb+srv://<username>:<password>@cluster.mongodb.net/SKT

# Comma-separated list of allowed origins for CORS
# Example for Railway: https://myapp-production.up.railway.app
# Example for local dev: http://localhost:3000,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
